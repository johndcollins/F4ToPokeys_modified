                                                                Visibility="{Binding Path=SoftLimitEnabled, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                            <TextBox Text="{Binding Path=SoftLimitMaximum, UpdateSourceTrigger=PropertyChanged}"
                                                                Margin="{StaticResource InlineLeftMargin}"
                                                                Width="75"
                                                                VerticalAlignment="Center"
                                                                Grid.Row="3" Grid.Column="1"
                                                                Visibility="{Binding Path=SoftLimitEnabled, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                        </Grid>
                                                    </Border>
                                                </Grid>
                                            </Grid>
                                        </StackPanel>
                                    </StackPanel>
                                </Expander>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding Path=StepperIdError}"
                                                 Value="{x:Null}">
                                        <Setter TargetName="StepperIdErrorIcon"
                                                Property="Visibility"
                                                Value="Hidden" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Path=Error}"
                                                 Value="{x:Null}">
                                        <Setter TargetName="StepperErrorIcon"
                                                Property="Visibility"
                                                Value="Hidden" />
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                            <Button Content="{x:Static lang:Main.AddStepperButton}"
                                    HorizontalAlignment="Left"
                                    Margin="{StaticResource StackedTopMargin}"
                                    Command="{Binding Path=PoVID6066.AddStepperCommand}"
                                    Visibility="{Binding Path=PoVID6066.StepperSlotsAvailable, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        </StackPanel>
                    </TabItem>
                </TabControl>
            </GroupBox.Content>
        </GroupBox>
        <DataTemplate.Triggers>
            <DataTrigger Binding="{Binding Path=Error}"
                         Value="{x:Null}">
                <Setter TargetName="PoKeysErrorIcon"
                        Property="Visibility"
                        Value="Hidden" />
            </DataTrigger>
        </DataTemplate.Triggers>
    </DataTemplate>

</ResourceDictionary>
