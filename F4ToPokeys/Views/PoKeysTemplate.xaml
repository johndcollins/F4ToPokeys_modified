<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:my="clr-namespace:F4ToPokeys"
                    xmlns:lang="clr-namespace:F4ToPokeys.Translations">

    <!-- StaticResource lookups inside a DataTemplate resolve against the template's
         lexical scope (this dictionary and anything it merges). Merge the shared
         converter dictionary so {StaticResource BooleanToVisibilityConverter} etc. work. -->
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/F4ToPokeys;component/Resources/Converters.xaml" />
        <ResourceDictionary Source="/F4ToPokeys;component/Themes/CommonTheme.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <!-- Group header template for the sorted+grouped FalconLightCollectionView. Local
         to this file because only PoKeys sub-templates consume it. -->
    <DataTemplate x:Key="FalconLightGroupTemplate"
                  DataType="{x:Type CollectionViewGroup}">
        <TextBlock Text="{Binding Path=Name}"
                   Margin="0,5,0,0"
                   Padding="3"
                   Background="{DynamicResource GroupHeaderBrush}"
                   Foreground="{DynamicResource TextBrush}" />
    </DataTemplate>

    <DataTemplate DataType="{x:Type my:PoKeys}">
        <GroupBox Margin="{StaticResource GroupBoxMargin}">
            <GroupBox.Header>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Name:"
                               VerticalAlignment="Center"
                               Margin="0,0,5,0" />
                    <TextBox Text="{Binding Path=Name, UpdateSourceTrigger=PropertyChanged}"
                             Width="160"
                             VerticalAlignment="Center" />
                    <TextBlock Text="{x:Static lang:Main.PoKeysConfigCaption}"
                               VerticalAlignment="Center"
                               Margin="{StaticResource InlineLeftMediumMargin}" />
                    <ComboBox ItemsSource="{Binding Path=AvailablePokeysList}"
                              SelectedItem="{Binding Path=SelectedPokeys}"
                              DisplayMemberPath="PokeysId"
                              IsSynchronizedWithCurrentItem="False"
                              Margin="{StaticResource InlineLeftMargin}"
                              Width="300"
                              VerticalAlignment="Center" />
                    <Image Name="PoKeysErrorIcon"
                           Source="{DynamicResource image_error}"
                           Width="{StaticResource {x:Static SystemParameters.SmallIconWidthKey}}"
                           ToolTip="{Binding Path=Error}"
                           Margin="{StaticResource InlineLeftMargin}"
                           VerticalAlignment="Center" />
                    <Button Content="{x:Static lang:Main.RemoveButton}"
                            Command="{Binding Path=RemovePoKeysCommand}"
                            Margin="{StaticResource InlineLeftMediumMargin}"
                            VerticalAlignment="Center" />
                </StackPanel>
            </GroupBox.Header>
            <GroupBox.Content>
                <TabControl>
                    <TabItem>
                        <TabItem.Header>
                            <TextBlock>
                                <Run Text="Digital " />
                                <Run Text="(" /><Run Text="{Binding Path=DigitalOutputList.Count, Mode=OneWay}" /><Run Text=")" />
                            </TextBlock>
                        </TabItem.Header>
                        <StackPanel Margin="0,5,0,0" TextElement.Foreground="{DynamicResource TextBrush}">
                            <StackPanel Orientation="Horizontal" Margin="{StaticResource StackedTopMargin}">
                                <Button Content="All On"
                                        ToolTip="Set every Digital output to ON for testing"
                                        Command="{Binding Path=AllDigitalOutputOnCommand}" />
                                <Button Content="All Off"
                                        ToolTip="Set every Digital output to OFF for testing"
                                        Margin="{StaticResource InlineLeftMargin}"
                                        Command="{Binding Path=AllDigitalOutputOffCommand}" />
                            </StackPanel>
                            <ItemsControl ItemsSource="{Binding Path=DigitalOutputList}"
                                          Margin="{StaticResource StackedTopMargin}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal"
                                            Margin="{StaticResource TinyMargin}">
                                    <TextBox Text="{Binding Path=Label, UpdateSourceTrigger=PropertyChanged}"
                                             Width="120"
                                             VerticalAlignment="Center" />
                                    <ComboBox ItemsSource="{x:Static my:DigitalOutput.PinIdList}"
                                              SelectedItem="{Binding Path=PinId}"
                                              Margin="{StaticResource InlineLeftMargin}"
                                              Width="50"
                                              VerticalAlignment="Center" />
                                    <Image Name="PinErrorIcon"
                                           Source="{DynamicResource image_error}"
                                           Width="{StaticResource {x:Static SystemParameters.SmallIconWidthKey}}"
                                           ToolTip="{Binding Path=Error}"
                                           Margin="{StaticResource InlineLeftMargin}"
                                           VerticalAlignment="Center" />
                                    <Image Name="PinOutputStateIcon"
                                           Source="{DynamicResource image_light_off}"
                                           Width="{StaticResource {x:Static SystemParameters.SmallIconWidthKey}}"
                                           Margin="{StaticResource InlineLeftMediumMargin}"
                                           VerticalAlignment="Center" />
                                    <Button Content="{x:Static lang:Main.FalconLightConsumerConfigOnButton}"
                                            Command="{Binding Path=SetOutputStateToOnCommand}"
                                            Margin="{StaticResource InlineLeftMargin}"
                                            VerticalAlignment="Center" />
                                    <Button Content="{x:Static lang:Main.FalconLightConsumerConfigOffButton}"
                                            Command="{Binding Path=SetOutputStateToOffCommand}"
                                            Margin="{StaticResource InlineLeftMargin}"
                                            VerticalAlignment="Center" />
                                    <ComboBox ItemsSource="{Binding Path=DataContext.FalconLightCollectionView, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                              SelectedItem="{Binding Path=FalconLight}"
                                              Margin="{StaticResource InlineLeftMediumMargin}"
                                              Width="200"
                                              DisplayMemberPath="Label"
                                              VerticalAlignment="Center"
                                              IsSynchronizedWithCurrentItem="False">
                                        <ComboBox.GroupStyle>
                                            <GroupStyle HeaderTemplate="{StaticResource FalconLightGroupTemplate}" />
                                        </ComboBox.GroupStyle>
                                    </ComboBox>
                                    <Button Content="{x:Static lang:Main.RemoveButton}"
                                            Command="{Binding Path=RemoveDigitalOutputCommand}"
                                            Margin="{StaticResource InlineLeftMediumMargin}"
                                            VerticalAlignment="Center" />
                                </StackPanel>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding Path=Error}"
                                                 Value="{x:Null}">
                                        <Setter TargetName="PinErrorIcon"
                                                Property="Visibility"
                                                Value="Hidden" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Path=OutputState}"
                                                 Value="true">
                                        <Setter TargetName="PinOutputStateIcon"
                                                Property="Source"
                                                Value="{DynamicResource image_light_on}" />
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Button Content="{x:Static lang:Main.AddDigitalOutputButton}"
                                    HorizontalAlignment="Left"
                                    Margin="{StaticResource StackedTopMargin}"
                                    Command="{Binding Path=AddDigitalOutputCommand}" />
                        </StackPanel>
                    </TabItem>
                    <TabItem>
                        <TabItem.Header>
                            <TextBlock>
                                <Run Text="Memory Slots " />
                                <Run Text="(" /><Run Text="{Binding Path=MemorySlotOutputList.Count, Mode=OneWay}" /><Run Text=")" />
                            </TextBlock>
                        </TabItem.Header>
                        <StackPanel Margin="0,5,0,0" TextElement.Foreground="{DynamicResource TextBrush}">
                            <ItemsControl ItemsSource="{Binding Path=MemorySlotOutputList}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal"
                                            Margin="{StaticResource TinyMargin}">
                                    <TextBlock Text="{Binding Path=Slot.Label}"
                                               VerticalAlignment="Center" Margin="{StaticResource InlineLeftMargin}" Width="170" />
                                    <TextBlock Text="{x:Static lang:Main.MemorySlotOutputSlotIdCaption}"
                                               VerticalAlignment="Center" Margin="{StaticResource InlineLeftMargin}" />
                                    <TextBlock Text="{Binding Path=SlotId}" HorizontalAlignment="Left"
                                               VerticalAlignment="Center" Margin="{StaticResource InlineLeftMargin}" Width="55" />
                                    <TextBlock Text="{x:Static lang:Main.MemorySlotOutputShiftBitsCaption}"
                                               VerticalAlignment="Center" Margin="{StaticResource InlineLeftMargin}" Width="55" />
                                    <TextBlock Text="{Binding Path=Slot.DisplayShiftBits}" HorizontalAlignment="Left"
                                               VerticalAlignment="Center" Margin="{StaticResource InlineLeftMargin}" Width="75" />
                                    <TextBlock Text="{x:Static lang:Main.MemorySlotOutputFormatCaption}"
                                               VerticalAlignment="Center" Margin="{StaticResource InlineLeftMargin}" Width="55" />
                                    <TextBlock Text="{Binding Path=Slot.Format}" HorizontalAlignment="Left"
                                               VerticalAlignment="Center" Margin="{StaticResource InlineLeftMargin}" Width="75" />
                                    <TextBlock Text="{x:Static lang:Main.MemorySlotOutputValueCaption}"
                                               VerticalAlignment="Center" Margin="{StaticResource InlineLeftMargin}" Width="55" />
                                    <TextBlock Text="{Binding Path=FalconValue, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Left"
                                               VerticalAlignment="Center" Margin="{StaticResource InlineLeftMargin}" Width="75" />
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Button Content="{x:Static lang:Main.EnableMemorySlotOutputButton}"
                                    HorizontalAlignment="Left"
                                    Margin="{StaticResource StackedTopMargin}"
                                    Command="{Binding Path=EnableMemorySlotOutputCommand}"
                                    Visibility="{Binding Path=AllowEnableMemorySlotOutput, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            <Button Content="{x:Static lang:Main.DisableMemorySlotOutputButton}"
                                    Command="{Binding Path=DisableMemorySlotOutputCommand}"
                                    HorizontalAlignment="Left"
                                    Margin="{StaticResource StackedTopMargin}"
                                    Visibility="{Binding Path=AllowDisableMemorySlotOutput, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        </StackPanel>
                    </TabItem>
                    <TabItem>
                        <TabItem.Header>
                            <TextBlock>
                                <Run Text="Matrix LED " />
                                <Run Text="(" /><Run Text="{Binding Path=MatrixLedOutputList.Count, Mode=OneWay}" /><Run Text=")" />
                            </TextBlock>
                        </TabItem.Header>
                        <StackPanel Margin="0,5,0,0" TextElement.Foreground="{DynamicResource TextBrush}">
                            <StackPanel Orientation="Horizontal" Margin="{StaticResource StackedTopMargin}">
                                <Button Content="All On"
                                        ToolTip="Set every Matrix LED output to ON for testing"
                                        Command="{Binding Path=AllMatrixLedOnCommand}" />
                                <Button Content="All Off"
                                        ToolTip="Set every Matrix LED output to OFF for testing"
                                        Margin="{StaticResource InlineLeftMargin}"
                                        Command="{Binding Path=AllMatrixLedOffCommand}" />
                            </StackPanel>
                            <ItemsControl ItemsSource="{Binding Path=MatrixLedOutputList}"
                                          Margin="{StaticResource StackedTopMargin}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal"
                                            Margin="{StaticResource TinyMargin}">
                                    <TextBox Text="{Binding Path=Label, UpdateSourceTrigger=PropertyChanged}"
                                             Width="120"
                                             VerticalAlignment="Center" />
                                    <ComboBox ItemsSource="{x:Static my:MatrixLed.AvailableMatrixLedList}"
                                              SelectedItem="{Binding Path=MatrixLed}"
                                              my:SelectorHelper.SelectIndexInDesignMode="0"
                                              Margin="{StaticResource InlineLeftMargin}"
                                              Width="80"
                                              VerticalAlignment="Center"
                                              DisplayMemberPath="Name" />
                                    <TextBlock Text="{x:Static lang:Main.MatrixLedOutputConfigRow}"
                                               Margin="{StaticResource InlineLeftMargin}"
                                               VerticalAlignment="Center" />
                                    <ComboBox ItemsSource="{x:Static my:MatrixLed.AvailableIndexList}"
                                              SelectedItem="{Binding Path=Row}"
                                              Margin="{StaticResource InlineLeftMargin}"
                                              Width="40"
                                              VerticalAlignment="Center" />
                                    <TextBlock Text="{x:Static lang:Main.MatrixLedOutputConfigColumn}"
                                               Margin="{StaticResource InlineLeftMargin}"
                                               VerticalAlignment="Center" />
                                    <ComboBox ItemsSource="{x:Static my:MatrixLed.AvailableIndexList}"
                                              SelectedItem="{Binding Path=Column}"
                                              Margin="{StaticResource InlineLeftMargin}"
                                              Width="40"
                                              VerticalAlignment="Center" />
                                    <Image Name="MatrixLedErrorIcon"
                                           Source="{DynamicResource image_error}"
                                           Width="{StaticResource {x:Static SystemParameters.SmallIconWidthKey}}"
                                           ToolTip="{Binding Path=Error}"
                                           Margin="{StaticResource InlineLeftMargin}"
                                           VerticalAlignment="Center" />
                                    <Image Name="MatrixLedOutputStateIcon"
                                           Source="{DynamicResource image_light_off}"
                                           Width="{StaticResource {x:Static SystemParameters.SmallIconWidthKey}}"
                                           Margin="{StaticResource InlineLeftMediumMargin}"
                                           VerticalAlignment="Center" />
                                    <Button Content="{x:Static lang:Main.FalconLightConsumerConfigOnButton}"
                                            Command="{Binding Path=SetOutputStateToOnCommand}"
                                            Margin="{StaticResource InlineLeftMargin}"
                                            VerticalAlignment="Center" />
                                    <Button Content="{x:Static lang:Main.FalconLightConsumerConfigOffButton}"
                                            Command="{Binding Path=SetOutputStateToOffCommand}"
                                            Margin="{StaticResource InlineLeftMargin}"
                                            VerticalAlignment="Center" />
                                    <ComboBox ItemsSource="{Binding Path=DataContext.FalconLightCollectionView, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                              SelectedItem="{Binding Path=FalconLight}"
                                              Margin="{StaticResource InlineLeftMediumMargin}"
                                              Width="200"
                                              DisplayMemberPath="Label"
                                              VerticalAlignment="Center"
                                              IsSynchronizedWithCurrentItem="False">
                                        <ComboBox.GroupStyle>
                                            <GroupStyle HeaderTemplate="{StaticResource FalconLightGroupTemplate}" />
                                        </ComboBox.GroupStyle>
                                    </ComboBox>
                                    <Button Content="{x:Static lang:Main.RemoveButton}"
                                            Command="{Binding Path=RemoveMatrixLedOutputCommand}"
                                            Margin="{StaticResource InlineLeftMediumMargin}"
                                            VerticalAlignment="Center" />
                                </StackPanel>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding Path=Error}"
                                                 Value="{x:Null}">
                                        <Setter TargetName="MatrixLedErrorIcon"
                                                Property="Visibility"
                                                Value="Hidden" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Path=OutputState}"
                                                 Value="true">
                                        <Setter TargetName="MatrixLedOutputStateIcon"
                                                Property="Source"
                                                Value="{DynamicResource image_light_on}" />
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                            <Button Content="{x:Static lang:Main.AddMatrixLedOutputButton}"
                                    HorizontalAlignment="Left"
                                    Margin="{StaticResource StackedTopMargin}"
                                    Command="{Binding Path=AddMatrixLedOutputCommand}" />
                        </StackPanel>
                    </TabItem>
                    <TabItem>
                        <TabItem.Header>
                            <TextBlock>
                                <Run Text="PoExtBus " />
                                <Run Text="(" /><Run Text="{Binding Path=PoExtBusOutputList.Count, Mode=OneWay}" /><Run Text=")" />
                            </TextBlock>
                        </TabItem.Header>
                        <StackPanel Margin="0,5,0,0" TextElement.Foreground="{DynamicResource TextBrush}">
                            <StackPanel Orientation="Horizontal" Margin="{StaticResource StackedTopMargin}">
                                <Button Content="All On"
                                        ToolTip="Set every PoExtBus output to ON for testing"
                                        Command="{Binding Path=AllPoExtBusOnCommand}" />
                                <Button Content="All Off"
                                        ToolTip="Set every PoExtBus output to OFF for testing"
                                        Margin="{StaticResource InlineLeftMargin}"
                                        Command="{Binding Path=AllPoExtBusOffCommand}" />
                            </StackPanel>
                            <ItemsControl ItemsSource="{Binding Path=PoExtBusOutputList}"
                                          Margin="{StaticResource StackedTopMargin}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal"
                                            Margin="{StaticResource TinyMargin}">
                                    <TextBox Text="{Binding Path=Label, UpdateSourceTrigger=PropertyChanged}"
                                             Width="120"
                                             VerticalAlignment="Center" />
                                    <ComboBox ItemsSource="{x:Static my:PoExtBus.AvailablePinIdList}"
                                              SelectedItem="{Binding Path=PinId}"
                                              Margin="{StaticResource InlineLeftMargin}"
                                              Width="40"
                                              VerticalAlignment="Center" />
                                    <TextBlock Text="{x:Static lang:Main.PoExtBusOutputConfigDevice}"
                                               Margin="{StaticResource InlineLeftMargin}"
                                               VerticalAlignment="Center" />
                                    <ComboBox ItemsSource="{x:Static my:PoExtBus.AvailableDeviceIdList}"
                                              SelectedItem="{Binding Path=DeviceId}"
                                              Margin="{StaticResource InlineLeftMargin}"
                                              Width="40"
                                              VerticalAlignment="Center" />
                                    <Image Name="PoExtBusErrorIcon"
                                           Source="{DynamicResource image_error}"
                                           Width="{StaticResource {x:Static SystemParameters.SmallIconWidthKey}}"
                                           ToolTip="{Binding Path=Error}"
                                           Margin="{StaticResource InlineLeftMargin}"
                                           VerticalAlignment="Center" />
                                    <Image Name="PoExtBusOutputStateIcon"
                                           Source="{DynamicResource image_light_off}"
                                           Width="{StaticResource {x:Static SystemParameters.SmallIconWidthKey}}"
                                           Margin="{StaticResource InlineLeftMediumMargin}"
                                           VerticalAlignment="Center" />
                                    <Button Content="{x:Static lang:Main.FalconLightConsumerConfigOnButton}"
                                            Command="{Binding Path=SetOutputStateToOnCommand}"
                                            Margin="{StaticResource InlineLeftMargin}"
                                            VerticalAlignment="Center" />
                                    <Button Content="{x:Static lang:Main.FalconLightConsumerConfigOffButton}"
                                            Command="{Binding Path=SetOutputStateToOffCommand}"
                                            Margin="{StaticResource InlineLeftMargin}"
                                            VerticalAlignment="Center" />
                                    <ComboBox ItemsSource="{Binding Path=DataContext.FalconLightCollectionView, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                              SelectedItem="{Binding Path=FalconLight}"
                                              Margin="{StaticResource InlineLeftMediumMargin}"
                                              Width="200"
                                              DisplayMemberPath="Label"
                                              VerticalAlignment="Center"
                                              IsSynchronizedWithCurrentItem="False">
                                        <ComboBox.GroupStyle>
                                            <GroupStyle HeaderTemplate="{StaticResource FalconLightGroupTemplate}" />
                                        </ComboBox.GroupStyle>
                                    </ComboBox>
                                    <Button Content="{x:Static lang:Main.RemoveButton}"
                                            Command="{Binding Path=RemovePoExtBusOutputCommand}"
                                            Margin="{StaticResource InlineLeftMediumMargin}"
                                            VerticalAlignment="Center" />
                                </StackPanel>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding Path=Error}"
                                                 Value="{x:Null}">
                                        <Setter TargetName="PoExtBusErrorIcon"
                                                Property="Visibility"
                                                Value="Hidden" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Path=OutputState}"
                                                 Value="true">
                                        <Setter TargetName="PoExtBusOutputStateIcon"
                                                Property="Source"
                                                Value="{DynamicResource image_light_on}" />
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                            <Button Content="{x:Static lang:Main.AddPoExtBusOutputButton}"
                                    HorizontalAlignment="Left"
                                    Margin="{StaticResource StackedTopMargin}"
                                    Command="{Binding Path=AddPoExtBusOutputCommand}" />
                        </StackPanel>
                    </TabItem>
                    <TabItem>
                        <TabItem.Header>
                            <TextBlock>
                                <Run Text="7-Segment " />
                                <Run Text="(" /><Run Text="{Binding Path=SevenSegmentDisplayList.Count, Mode=OneWay}" /><Run Text=")" />
                            </TextBlock>
                        </TabItem.Header>
                        <StackPanel Margin="0,5,0,0" TextElement.Foreground="{DynamicResource TextBrush}">
                            <ItemsControl ItemsSource="{Binding Path=SevenSegmentDisplayList}"
                                          Margin="{StaticResource StackedTopMargin}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Expander Margin="{StaticResource TinyMargin}">
                                    <Expander.Header>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{x:Static lang:Main.SevenSegmentDisplayConfigCaption}"
                                                       VerticalAlignment="Center" />
                                            <ComboBox ItemsSource="{x:Static my:MatrixLed.AvailableMatrixLedList}"
                                                      SelectedItem="{Binding Path=MatrixLed}"
                                                      my:SelectorHelper.SelectIndexInDesignMode="0"
                                                      Margin="{StaticResource InlineLeftMargin}"
                                                      Width="80"
                                                      VerticalAlignment="Center"
                                                      DisplayMemberPath="Name" />
                                            <Image Name="SevenSegmentErrorIcon"
                                                   Source="{DynamicResource image_error}"
                                                   Width="{StaticResource {x:Static SystemParameters.SmallIconWidthKey}}"
                                                   ToolTip="{Binding Path=Error}"
                                                   Margin="{StaticResource InlineLeftMargin}"
                                                   VerticalAlignment="Center" />
                                            <ItemsControl ItemsSource="{Binding Path=SevenSegmentDigits}"
                                                          Margin="{StaticResource InlineLeftMargin}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <StackPanel>
                                                            <my:SevenSegmentDigitControl Digit="{Binding}"
                                                                                         Background="{DynamicResource SevenSegmentBackgroundBrush}"
                                                                                         Margin="2,0,0,0"
                                                                                         Padding="3,3,1,3"
                                                                                         Width="24"
                                                                                         SnapsToDevicePixels="True"
                                                                                         FillOn="{DynamicResource SevenSegmentOnBrush}"
                                                                                         FillOff="{DynamicResource SevenSegmentOffBrush}" />
                                                            <TextBlock Text="{Binding Path=Index}"
                                                                       HorizontalAlignment="Center"
                                                                       FontSize="{StaticResource TinyFontSize}" />
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <DockPanel LastChildFill="False" />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemContainerStyle>
                                                    <Style>
                                                        <Setter Property="DockPanel.Dock"
                                                                Value="Right" />
                                                    </Style>
                                                </ItemsControl.ItemContainerStyle>
                                            </ItemsControl>
                                            <ComboBox ItemsSource="{Binding Path=DataContext.FalconGaugeCollectionView, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                                      SelectedItem="{Binding Path=FalconGauge}"
                                                      Margin="{StaticResource InlineLeftMediumMargin}"
                                                      Width="200"
                                                      DisplayMemberPath="Label"
                                                      VerticalAlignment="Center"
                                                      IsSynchronizedWithCurrentItem="False" />
                                            <TextBox Text="{Binding Path=FalconValue, UpdateSourceTrigger=PropertyChanged}"
                                                     Margin="{StaticResource InlineLeftMargin}"
                                                     Width="75"
                                                     VerticalAlignment="Center" />
                                            <Button Content="{x:Static lang:Main.RemoveButton}"
                                                    Command="{Binding Path=RemoveSevenSegmentDisplayCommand}"
                                                    Margin="{StaticResource InlineLeftMediumMargin}"
                                                    VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Expander.Header>
                                    <StackPanel Margin="{StaticResource ExpanderContentMargin}">
                                        <StackPanel Orientation="Horizontal"
                                                    Grid.IsSharedSizeScope="True">
                                            <ItemsControl ItemsSource="{Binding Path=FalconGaugeDigits}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="1,0,1,0"
                                                              Width="32">
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition SharedSizeGroup="DigitRow" />
                                                                <RowDefinition Height="5" />
                                                                <RowDefinition SharedSizeGroup="DigitIndexRow" />
                                                            </Grid.RowDefinitions>
                                                            <Grid Background="{DynamicResource GaugeDigitBackgroundBrush}">
                                                                <StackPanel Orientation="Horizontal"
                                                                            HorizontalAlignment="Center"
                                                                            TextBlock.FontSize="{StaticResource LargeFontSize}">
                                                                    <TextBlock Text="{Binding Path=Value}" Foreground="Black" />
                                                                    <TextBlock Text="."
                                                                               Foreground="Black"
                                                                               Visibility="{Binding Path=DecimalPoint, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                                </StackPanel>
                                                            </Grid>
                                                            <ComboBox ItemsSource="{x:Static my:FalconGaugeDigit.AvailableIndexList}"
                                                                      SelectedItem="{Binding Path=SevenSegmentDigitIndex, Converter={StaticResource SevenSegmentDigitIndexConverter}}"
                                                                      Margin="1,0"
                                                                      FontSize="{StaticResource SmallFontSize}"
                                                                      Grid.Row="2">
                                                            </ComboBox>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <DockPanel LastChildFill="False" />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemContainerStyle>
                                                    <Style>
                                                        <Setter Property="DockPanel.Dock"
                                                                Value="Right" />
                                                    </Style>
                                                </ItemsControl.ItemContainerStyle>
                                            </ItemsControl>
                                            <Grid Margin="{StaticResource InlineLeftMediumMargin}">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition SharedSizeGroup="DigitRow" />
                                                    <RowDefinition Height="5" />
                                                    <RowDefinition SharedSizeGroup="DigitIndexRow" />
                                                </Grid.RowDefinitions>
                                                <StackPanel Orientation="Horizontal">
                                                    <StackPanel>
                                                        <Button Content="{x:Static lang:Main.IncrementTotalSizeButton}"
                                                                Command="{Binding Path=FalconGaugeFormat.IncrementTotalSizeCommand}" />
                                                        <Button Content="{x:Static lang:Main.DecrementTotalSizeButton}"
                                                                Command="{Binding Path=FalconGaugeFormat.DecrementTotalSizeCommand}"
                                                                Margin="0,3,0,0" />
                                                    </StackPanel>
                                                    <StackPanel Margin="{StaticResource InlineLeftMediumMargin}">
                                                        <Grid>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition />
                                                                <RowDefinition Height="5" />
                                                                <RowDefinition />
                                                            </Grid.RowDefinitions>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition />
                                                                <ColumnDefinition />
                                                                <ColumnDefinition />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Text="{x:Static lang:Main.IntegralPartMinSizeCaption}"
                                                                       VerticalAlignment="Center"
                                                                       Grid.Row="0"
                                                                       Grid.Column="0" />
                                                            <TextBox Text="{Binding Path=FalconGaugeFormat.IntegralPartMinSize, UpdateSourceTrigger=PropertyChanged}"
                                                                     Margin="{StaticResource InlineLeftMargin}"
                                                                     Width="50"
                                                                     VerticalAlignment="Center"
                                                                     Grid.Row="0"
                                                                     Grid.Column="1" />
                                                            <TextBlock Text="{x:Static lang:Main.FractionalPartSizeCaption}"
                                                                       Grid.Row="2"
                                                                       Grid.Column="0"
                                                                       VerticalAlignment="Center" />
                                                            <TextBox Text="{Binding Path=FalconGaugeFormat.FractionalPartSize, UpdateSourceTrigger=PropertyChanged}"
                                                                     Margin="{StaticResource InlineLeftMargin}"
                                                                     Width="50"
                                                                     VerticalAlignment="Center"
                                                                     Grid.Row="2"
                                                                     Grid.Column="1" />
                                                            <CheckBox Content="{x:Static lang:Main.PadFractionalPartWithZeroCaption}"
                                                                      IsChecked="{Binding Path=FalconGaugeFormat.PadFractionalPartWithZero}"
                                                                      Margin="{StaticResource InlineLeftMargin}"
                                                                      VerticalAlignment="Center"
                                                                      Grid.Row="2"
                                                                      Grid.Column="2" />
                                                        </Grid>
                                                    </StackPanel>
                                                </StackPanel>
                                                <Grid Grid.Row="2"
                                                      Visibility="{Binding Path=MatrixLedConfig, Converter={StaticResource NullToHiddenConverter}}">
                                                    <TextBlock Text="{x:Static lang:Main.SevenSegmentDigitRowCaption}"
                                                               VerticalAlignment="Center"
