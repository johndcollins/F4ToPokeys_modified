<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- Spacing tokens -->
    <Thickness x:Key="TinyMargin">2</Thickness>
    <Thickness x:Key="SmallMargin">5</Thickness>
    <Thickness x:Key="MediumMargin">10</Thickness>
    <Thickness x:Key="LargeMargin">15</Thickness>

    <Thickness x:Key="InlineLeftMargin">5,0,0,0</Thickness>
    <Thickness x:Key="InlineLeftMediumMargin">10,0,0,0</Thickness>
    <Thickness x:Key="InlineLeftLargeMargin">15,0,0,0</Thickness>
    <Thickness x:Key="StackedTopMargin">0,10,0,0</Thickness>
    <Thickness x:Key="StackedTopSmallMargin">0,5,0,0</Thickness>
    <Thickness x:Key="GroupBoxMargin">0,5,0,5</Thickness>
    <Thickness x:Key="ExpanderContentMargin">20,5,0,5</Thickness>
    <Thickness x:Key="PanelPadding">5</Thickness>
    <Thickness x:Key="StatusBarPadding">8,4</Thickness>

    <!-- Font tokens -->
    <sys:Double x:Key="SmallFontSize">10</sys:Double>
    <sys:Double x:Key="TinyFontSize">8</sys:Double>
    <sys:Double x:Key="DefaultFontSize">12</sys:Double>
    <sys:Double x:Key="HeaderFontSize">14</sys:Double>
    <sys:Double x:Key="LargeFontSize">36</sys:Double>

    <!-- Dimension tokens -->
    <sys:Double x:Key="StatusDotSize">10</sys:Double>
    <sys:Double x:Key="TreeItemDotSize">8</sys:Double>

    <!-- Shared 7-segment pre-existing fills (hardware-accurate, NOT theme colors) -->
    <SolidColorBrush x:Key="SevenSegmentBackgroundBrush" Color="DarkSlateGray" />
    <SolidColorBrush x:Key="SevenSegmentOnBrush" Color="LightGreen" />
    <SolidColorBrush x:Key="SevenSegmentOffBrush" Color="DarkViolet" />
    <SolidColorBrush x:Key="SevenSegmentStrokeBrush" Color="Green" />
    <SolidColorBrush x:Key="GaugeDigitBackgroundBrush" Color="Beige" />

    <!-- Shared spacing-only styles used by both themes -->
    <Style x:Key="SegmentIndexTextBlockStyle" TargetType="TextBlock">
        <Setter Property="Margin" Value="0,0,4,0" />
        <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>

</ResourceDictionary>
