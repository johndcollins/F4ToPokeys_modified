<Window x:Class="F4ToPokeys.ConfigurationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:my="clr-namespace:F4ToPokeys"
        xmlns:lang="clr-namespace:F4ToPokeys.Translations"
        mc:Ignorable="d"
        Title="{Binding Path=Title}"
        Icon="Resources/F4ToPokeys.ico"
        Width="1100"
        Height="750"
        Background="{DynamicResource BackgroundBrush}"
        Foreground="{DynamicResource TextBrush}"
        Unloaded="Window_Unloaded"
        d:DataContext="{d:DesignData Source=Resources/ConfigurationDialogDesignData.xaml}">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Views/PoKeysTemplate.xaml" />
                <ResourceDictionary Source="Views/PololuMaestroTemplate.xaml" />
                <ResourceDictionary Source="Views/DEDuinoTemplate.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Right-panel detail template for group summary (cards) -->
            <DataTemplate x:Key="DeviceGroupDetailTemplate"
                          DataType="{x:Type my:DeviceGroupViewModel}">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top"
                                Orientation="Horizontal"
                                Margin="{StaticResource PanelPadding}">
                        <TextBlock Text="{Binding Path=GroupName}"
                                   FontSize="{StaticResource HeaderFontSize}"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center" />
                        <Button Margin="{StaticResource InlineLeftMediumMargin}"
                                VerticalAlignment="Center"
                                Command="{Binding Path=AddDeviceCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                    <Setter Property="Content" Value="{x:Static lang:Main.AddPoKeysButton}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Path=Kind}" Value="PololuMaestro">
                                            <Setter Property="Content" Value="{x:Static lang:Main.AddPololuMaestroButton}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Path=Kind}" Value="DEDuino">
                                            <Setter Property="Content" Value="{x:Static lang:Main.AddDEDuinoButton}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Path=Devices}" Margin="{StaticResource PanelPadding}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource PanelBrush}"
                                            BorderBrush="{DynamicResource BorderBrush}"
                                            BorderThickness="1"
                                            Padding="{StaticResource PanelPadding}"
                                            Margin="{StaticResource StackedTopSmallMargin}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Path=DisplayName}"
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center"
                                                       MinWidth="240" />
                                            <TextBlock Text="{Binding Path=Error}"
                                                       Foreground="{DynamicResource ErrorBrush}"
                                                       VerticalAlignment="Center"
                                                       Margin="{StaticResource InlineLeftMediumMargin}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </DataTemplate>

        </ResourceDictionary>
    </Window.Resources>

    <DockPanel LastChildFill="True">
        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom"
                Background="{DynamicResource PanelBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="{StaticResource StatusBarPadding}">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                    <Ellipse Width="{StaticResource StatusDotSize}"
                             Height="{StaticResource StatusDotSize}"
                             VerticalAlignment="Center">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="{DynamicResource StatusDisconnectedBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Path=IsFalconConnected}" Value="True">
                                        <Setter Property="Fill" Value="{DynamicResource StatusConnectedBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="Falcon BMS"
                               VerticalAlignment="Center"
                               Margin="6,0,0,0" />
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="{Binding Path=ThemeToggleLabel}"
                            Command="{Binding Path=ToggleThemeCommand}"
                            VerticalAlignment="Center" />
                    <Button Content="Save"
                            Command="{Binding Path=SaveCommand}"
                            Margin="{StaticResource InlineLeftMargin}"
                            VerticalAlignment="Center" />
                    <Button Content="Load"
                            Command="{Binding Path=LoadCommand}"
                            Margin="{StaticResource InlineLeftMargin}"
                            VerticalAlignment="Center" />
                </StackPanel>
                <TextBlock />
            </DockPanel>
        </Border>

        <!-- Master-detail body -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" MinWidth="180" />
                <ColumnDefinition Width="4" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Left nav -->
            <DockPanel Grid.Column="0" Background="{DynamicResource PanelBrush}">
                <StackPanel DockPanel.Dock="Top"
                            Orientation="Horizontal"
                            Margin="{StaticResource PanelPadding}">
                    <Label Content="{x:Static lang:Main.FalconSamplingInterval}"
                           VerticalAlignment="Center" />
                    <TextBox Width="50"
                             Text="{Binding Path=ConfigHolder.Configuration.ReadFalconDataTimerIntervalMS, UpdateSourceTrigger=PropertyChanged, ValidatesOnExceptions=True}"
                             VerticalAlignment="Center" />
                    <TextBlock Text="{x:Static lang:Main.FalconSamplingUnit}"
                               VerticalAlignment="Center"
                               Margin="{StaticResource InlineLeftMargin}" />
                </StackPanel>
                <TreeView ItemsSource="{Binding Path=DeviceGroups}"
                          SelectedItemChanged="DeviceTree_SelectedItemChanged"
                          BorderThickness="0">
                    <TreeView.Resources>
                        <!-- Keep selection readable regardless of TreeView focus.
                             Both active and inactive selection use the same themed
                             accent background + white text. -->
                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}"
                                         Color="{DynamicResource AccentColor}" />
                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}"
                                         Color="White" />
                        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}"
                                         Color="{DynamicResource AccentColor}" />
                        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}"
                                         Color="White" />

                        <!-- Tree-scoped leaf templates; scoped here so they don't shadow
                             the detail DataTemplates from Views/*.xaml. -->
                        <DataTemplate DataType="{x:Type my:PoKeys}">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="{StaticResource TreeItemDotSize}"
                                         Height="{StaticResource TreeItemDotSize}"
                                         VerticalAlignment="Center"
                                         Margin="0,0,6,0">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="{DynamicResource StatusDisconnectedBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Path=Connected}" Value="True">
                                                    <Setter Property="Fill" Value="{DynamicResource StatusConnectedBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock Text="{Binding Path=DisplayName}" VerticalAlignment="Center" />
                            </StackPanel>
                        </DataTemplate>

                        <DataTemplate DataType="{x:Type my:PololuMaestro}">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="{StaticResource TreeItemDotSize}"
                                         Height="{StaticResource TreeItemDotSize}"
                                         VerticalAlignment="Center"
                                         Margin="0,0,6,0">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="{DynamicResource StatusErrorBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Path=Error}" Value="{x:Null}">
                                                    <Setter Property="Fill" Value="{DynamicResource StatusConnectedBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock Text="{Binding Path=DisplayName}" VerticalAlignment="Center" />
                            </StackPanel>
                        </DataTemplate>

                        <DataTemplate DataType="{x:Type my:DEDuino}">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="{StaticResource TreeItemDotSize}"
                                         Height="{StaticResource TreeItemDotSize}"
                                         VerticalAlignment="Center"
                                         Margin="0,0,6,0">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="{DynamicResource StatusErrorBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Path=Error}" Value="{x:Null}">
                                                    <Setter Property="Fill" Value="{DynamicResource StatusConnectedBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock Text="{Binding Path=DisplayName}" VerticalAlignment="Center" />
                            </StackPanel>
                        </DataTemplate>

                        <HierarchicalDataTemplate DataType="{x:Type my:DeviceGroupViewModel}"
                                                  ItemsSource="{Binding Path=Devices}">
                            <StackPanel Orientation="Horizontal">
                                <StackPanel.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Command="{Binding Path=AddDeviceCommand}">
                                            <MenuItem.Header>
                                                <TextBlock>
                                                    <Run Text="Add " /><Run Text="{Binding Path=GroupName, Mode=OneWay}" />
                                                </TextBlock>
                                            </MenuItem.Header>
                                        </MenuItem>
                                    </ContextMenu>
                                </StackPanel.ContextMenu>
                                <TextBlock Text="{Binding Path=GroupName}"
                                           FontWeight="Bold"
                                           VerticalAlignment="Center" />
                                <Button Content="+"
                                        Command="{Binding Path=AddDeviceCommand}"
                                        ToolTip="Add"
                                        Margin="6,0,0,0"
                                        Padding="6,0"
                                        MinWidth="20"
                                        VerticalAlignment="Center" />
                            </StackPanel>
                        </HierarchicalDataTemplate>
                    </TreeView.Resources>
                </TreeView>
            </DockPanel>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1"
                          Width="4"
                          HorizontalAlignment="Stretch"
                          Background="{DynamicResource BorderBrush}" />

            <!-- Right detail. -->
            <ScrollViewer Grid.Column="2"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Auto"
                          Background="{DynamicResource BackgroundBrush}">
                <Grid Margin="{StaticResource PanelPadding}">
                    <!-- Only one ContentPresenter. When SelectedDevice is a DeviceGroupViewModel
                         the keyed group-detail template is used; otherwise implicit DataType
                         dispatch finds the matching device detail template from Views/*.xaml.
                         Trigger binds via RelativeSource to the Window's DataContext (the VM),
                         not the ContentPresenter's own DataContext which WPF sets to Content. -->
                    <ContentPresenter Content="{Binding Path=SelectedDevice}">
                        <ContentPresenter.Style>
                            <Style TargetType="ContentPresenter">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Path=DataContext.IsGroupSelected, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                                 Value="True">
                                        <Setter Property="ContentTemplate" Value="{StaticResource DeviceGroupDetailTemplate}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ContentPresenter.Style>
                    </ContentPresenter>
                </Grid>
            </ScrollViewer>
        </Grid>
    </DockPanel>
</Window>
